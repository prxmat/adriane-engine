    "@typescript-eslint/parser": "^8.33.1",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.5.3",
    "turbo": "^2.5.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.6"
