{
  "name": "@adriane-ai/napi",
  "version": "1.21.0",
  "license": "Apache-2.0",
  "description": "Node bindings to the Adriane Rust engine (graph validation, DSL compile, run/resume/approve).",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "adriane_napi.*.node",
    "LICENSE",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "napi": {
    "binaryName": "adriane_napi",
    "packageName": "@adriane-ai/napi",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build:napi": "napi build --platform --release --js napi-generated.js --dts napi-generated.d.ts",
    "build:napi:debug": "napi build --platform --js napi-generated.js --dts napi-generated.d.ts",
    "artifacts": "napi artifacts",
    "prepublish:napi": "napi pre-publish --tag-style npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  }
}
