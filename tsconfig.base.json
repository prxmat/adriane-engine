{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@adriane-ai/graph-core": [
        "packages/graph-core/src/index.ts"
      ],
      "@adriane-ai/graph-runtime": [
        "packages/graph-runtime/src/index.ts"
      ],
      "@adriane-ai/graph-sdk": [
        "packages/graph-sdk/src/index.ts"
      ],
      "@adriane-ai/agents-core": [
        "packages/agents-core/src/index.ts"
      ],
      "@adriane-ai/llm-gateway": [
        "packages/llm-gateway/src/index.ts"
      ],
      "@adriane-ai/artifact-store": [
        "packages/artifact-store/src/index.ts"
      ],
      "@adriane-ai/approval-engine": [
        "packages/approval-engine/src/index.ts"
      ],
      "@adriane-ai/observability": [
        "packages/observability/src/index.ts"
      ],
      "@adriane-ai/lang-adriane": [
        "packages/lang-adriane/src/index.ts"
      ],
      "@adriane-ai/graph-adriane": [
        "packages/graph-adriane/src/index.ts"
      ],
      "@adriane-ai/cli": [
        "packages/adriane-cli/src/cli.ts"
      ],
      "@adriane-ai/contracts": [
        "packages/contracts/src/index.ts"
      ],
      "@adriane-ai/okf": [
        "packages/okf/src/index.ts"
      ],
      "@adriane-ai/knowledge": [
        "packages/knowledge/src/index.ts"
      ],
      "@adriane-ai/search": [
        "packages/search/src/index.ts"
      ],
      "@adriane-ai/ui": [
        "product/packages/ui/src/index.ts"
      ],
      "@adriane-ai/config": [
        "packages/config/src/index.ts"
      ],
      "@adriane-ai/db": [
        "product/packages/db/src/index.ts"
      ],
      "@adriane-ai/db-adapters": [
        "product/packages/db-adapters/src/index.ts"
      ]
    }
  }
}
