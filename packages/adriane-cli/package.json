{
  "name": "@adriane-ai/cli",
  "license": "Apache-2.0",
  "version": "1.2.0",
  "description": "The Adriane command-line — author, validate, compile and run Adriane DSL graphs. Self-contained bundle; the `adriane` command works after a global install.",
  "type": "module",
  "bin": {
    "adriane": "./dist/adriane.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.6"
  }
}
